#!/usr/bin/env python3
"""Git pre-commit hook wrapper for ADR-042 committed gate records."""

from __future__ import annotations

import subprocess
import sys
from pathlib import Path


def _branch() -> str:
    result = subprocess.run(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True,
        text=True,
        check=False,
    )
    return result.stdout.strip()


def main() -> int:
    branch = _branch()
    if branch in {"main", "develop", "HEAD"}:
        return 0

    repo_root = Path(__file__).resolve().parents[2]
    result = subprocess.run(
        [
            sys.executable,
            str(repo_root / "scripts" / "hooks" / "run_python_module.py"),
            "scieasy.qa.governance.gate_record",
            "pre-commit",
            "--staged",
        ],
        text=True,
        check=False,
        cwd=repo_root,
    )
    return result.returncode


if __name__ == "__main__":
    raise SystemExit(main())
