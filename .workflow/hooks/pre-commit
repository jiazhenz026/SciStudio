#!/usr/bin/env python3
"""Git pre-commit hook wrapper for ADR-042 committed gate records."""

from __future__ import annotations

import re
import subprocess
import sys
from pathlib import Path

# Generated-artefact denylist (#1311 / ADR-042 Addendum 1 D9 follow-up).
# Files matching any of these patterns MUST NOT be committed — they are
# build/audit/runtime artefacts that should live outside git. .gitignore
# alone is not enough because already-tracked files stay tracked; this
# hook is the second line of defence after `git rm --cached`.
#
# To add a pattern: append a Python regex (anchored against the staged
# path relative to repo root, forward slashes). Keep the rationale next
# to the entry.
_DENY_PATTERNS: list[tuple[str, str]] = [
    (
        r"^docs/audit/full-audit-latest\.json$",
        "generated by `scistudio.qa.audit.full_audit --output`; "
        "track-and-merge causes recurring modify/delete conflicts on umbrella "
        "branches (PR #1290 D9 cleanup, PR #1310 hotfix retread). Use a "
        "git-ignored output path or accept the file is local-only.",
    ),
]


def _branch() -> str:
    result = subprocess.run(
        ["git", "rev-parse", "--abbrev-ref", "HEAD"],
        capture_output=True,
        text=True,
        check=False,
    )
    return result.stdout.strip()


def _staged_paths() -> list[str]:
    """Return paths staged for the upcoming commit, relative to repo root,
    forward-slash normalised. Includes added + modified + renamed targets."""
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=AMRC"],
        capture_output=True,
        text=True,
        check=False,
    )
    return [
        line.strip().replace("\\", "/")
        for line in result.stdout.splitlines()
        if line.strip()
    ]


def _check_denylist() -> int:
    """Reject the commit if any staged path matches a denylist pattern.
    Returns 0 if clean, 1 if any pattern matched (writes diagnostics to stderr)."""
    staged = _staged_paths()
    if not staged:
        return 0
    violations: list[tuple[str, str]] = []
    for path in staged:
        for pattern, rationale in _DENY_PATTERNS:
            if re.match(pattern, path):
                violations.append((path, rationale))
                break
    if not violations:
        return 0
    print(
        "\nERROR: pre-commit denied staged files (generated-artefact denylist)",
        file=sys.stderr,
    )
    for path, rationale in violations:
        print(f"  - {path}", file=sys.stderr)
        print(f"      reason: {rationale}", file=sys.stderr)
    print(
        "\nTo unstage and continue:",
        file=sys.stderr,
    )
    for path, _ in violations:
        print(f"  git restore --staged {path}", file=sys.stderr)
    print(
        "\nIf the file was previously tracked and should no longer be, also run:",
        file=sys.stderr,
    )
    print("  git rm --cached <path>", file=sys.stderr)
    print(
        "\nDenylist defined in .workflow/hooks/pre-commit `_DENY_PATTERNS`.\n",
        file=sys.stderr,
    )
    return 1


def main() -> int:
    branch = _branch()
    if branch in {"main", "develop", "HEAD"}:
        return 0

    # Generated-artefact denylist runs first so its diagnostic is visible
    # even when gate_record would also fail. Both checks must pass.
    deny_rc = _check_denylist()
    if deny_rc != 0:
        return deny_rc

    repo_root = Path(__file__).resolve().parents[2]
    result = subprocess.run(
        [
            sys.executable,
            str(repo_root / "scripts" / "hooks" / "run_python_module.py"),
            "scistudio.qa.governance.gate_record",
            "pre-commit",
            "--staged",
        ],
        text=True,
        check=False,
        cwd=repo_root,
    )
    return result.returncode


if __name__ == "__main__":
    raise SystemExit(main())
