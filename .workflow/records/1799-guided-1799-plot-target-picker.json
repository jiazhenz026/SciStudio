    {
      "at": "2026-06-27T08:04:27.994923Z",
      "owner_directive": "Three picker tweaks: (1) move the Create button next to the Language select (new-plot form row), not the header; (2) change the canvas-block\u2192plot-card highlight ring to a green/striking color instead of ink; (3) make the 'Bind to' target rows single-line instead of two lines to save vertical space.",
      "reason": "owner UX feedback after live test of the in-panel picker"
    },
    {
      "at": "2026-06-27T08:06:08.859183Z",
      "owner_directive": "Revert tweak #1 (do NOT move the Create button). Keep: (2) green/striking card highlight ring for canvas-block\u2192plot-card, (3) single-line Bind-to rows, and (4) slow down the canvas auto-center pan (350ms\u2192700ms) so it glides instead of snapping.",
      "reason": "owner narrowed UX tweaks after live test"
    }
