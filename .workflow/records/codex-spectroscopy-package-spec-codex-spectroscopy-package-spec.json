  "directive_events": [
    {
      "at": "2026-06-14T02:54:40.380106Z",
      "owner_directive": "Use this document as the Spectroscopy package spec; continue adding blocks into it as owner-approved.",
      "reason": "Owner renamed the draft to the broader Spectroscopy package spec before block discussion."
    },
    {
      "at": "2026-06-14T03:04:23.456393Z",
      "owner_directive": "Add accepted utilities: LoadSpectrum, SaveSpectrum, LoadSpectralDataset, SaveSpectralDataset, SpectrumToSpectralDataset, SpectralDatasetToSpectrum, FilterSpectralDataset, and MergeSpectralDataset; spectrum_id is an internal unique ID, not default filename; filename/source_file may be used as metadata join keys.",
      "reason": "Owner accepted the initial Spectroscopy utility block set."
    },
    {
      "at": "2026-06-14T03:20:21.099210Z",
      "owner_directive": "Add accepted preprocessing blocks: CropSpectrumRange, ShiftSpectralAxis, BaselineCorrection, SmoothSpectrum, AlignAndResampleSpectra, NormalizeSpectrum, and SubtractPeakComponent. Preprocessing operates on Collection[Spectrum], not SpectralDataset. Baseline methods are polynomial/asls/arpls/airpls only. Normalize methods are max/minmax only. SubtractPeakComponent supports gaussian/lorentzian/voigt. Any fitting or baseline-estimation preprocessing block must expose fitted-curve output and fit_diagnostics DataFrame ports.",
      "reason": "Owner accepted the initial Spectroscopy preprocessing block set."
    },
    {
      "at": "2026-06-14T03:33:34.896322Z",
      "owner_directive": "Feature extraction blocks should accept Collection[Spectrum] and output ordinary DataFrame feature tables keyed by spectrum_id; add AttachFeaturesToSpectralDataset as a utility that joins feature tables back into SpectralDataset.index.",
      "reason": "Owner accepted feature-table mapping utility design"
    },
    {
      "at": "2026-06-14T03:35:28.717535Z",
      "owner_directive": "Add feature extraction blocks FindPeaks and CalculateCentroid. Both should accept Collection[Spectrum] and output flat DataFrame feature tables keyed by spectrum_id; CalculateCentroid computes centroid within a configured lambda range.",
      "reason": "Owner accepted first feature extraction blocks"
    },
    {
      "at": "2026-06-14T04:51:45.482947Z",
      "owner_directive": "Expand feature extraction/measurement blocks to include ExtractIntensity, CalculateAUC, CalculateCentroid, CalculateRatio, and FindPeaks. All measurement/feature blocks accept Collection[Spectrum] and output flat DataFrame values that can merge into SpectralDataset.index. CalculateRatio is peak-to-peak ratio from two user-specified peaks. Do not add a separate FWHM block; peak fitting diagnostics should include FWHM.",
      "reason": "Owner accepted expanded feature measurement set"
    },
    {
      "at": "2026-06-14T05:02:37.150118Z",
      "owner_directive": "Add FitPeak with gaussian, lorentzian, and voigt models; outputs must include fitted curves, residuals, and features/parameters table instead of diagnostics naming. Add library matching with selectable matching methods. Calibration and clustering are intentionally out of scope for this draft, and no other blocks are added.",
      "reason": "Owner accepted peak fitting and library matching blocks"
    },
    {
      "at": "2026-06-14T05:28:04.151811Z",
      "owner_directive": "Add ADR-043-compliant spectroscopy IO format capability requirements and matrices; SPC is load/save, vendor/native instrument formats are load-only, txt is supported, SpectralDataset follows core CompositeData manifest contract rather than invented zip semantics.",
      "reason": "Owner accepted spectroscopy IO format support scope"
    },
    {
      "at": "2026-06-14T05:41:35.902152Z",
      "owner_directive": "Rename/move the spectroscopy package spec from specs/001-spectroscopy-package/spec.md to docs/specs/spectroscopy-package.md so frontmatter_lint, doc_drift, and closure include it in full_audit.",
      "reason": "Move spectroscopy package spec into docs/specs so existing full_audit scans it"
    },
    {
      "at": "2026-06-14T05:55:21.238299Z",
      "owner_directive": "Write a separate spec for unified package interface discovery, contract tests, and production/runtime validation for every installed package.",
      "reason": "Owner requested a new generic package interface and contract-test spec after spectroscopy package IO/previewer audit discussion."
    },
    {
      "at": "2026-06-14T06:03:42.788246Z",
      "owner_directive": "Limit this PR to docs/specs/spectroscopy-package.md; do not include docs/specs/package-interface-contract-tests.md.",
      "reason": "Owner asked to push only the spectroscopy package spec now and leave the generic package contract-test spec for later review."
    }
  ],
