{
  "name": "scistudio-desktop",
  "version": "0.1.0",
  "private": true,
  "description": "SciStudio ADR-037 desktop MVP shell",
  "author": "SciStudio",
  "main": "main.js",
  "type": "commonjs",
  "scripts": {
    "build:frontend": "npm --prefix ../frontend run build",
    "stage": "powershell -ExecutionPolicy Bypass -File ./scripts/stage-resources.ps1",
    "stage:sh": "sh ./scripts/stage-resources.sh",
    "start": "node scripts/start-electron.js",
    "dev": "node scripts/start-dev.js",
    "dist:dir": "electron-builder --dir"
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "42.2.0",
    "electron-builder": "26.8.1"
  },
  "build": {
    "appId": "org.scistudio.desktop",
    "productName": "SciStudio",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources",
        "to": ".",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": "dir",
      "signAndEditExecutable": false
    }
  }
}
